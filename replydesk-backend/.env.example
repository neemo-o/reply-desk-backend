# ─── APP ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── DOCKER (ports externos) ────────────────────────────────
# Estes são os HOST ports mapeados no docker-compose.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=whatsapp_saas
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── DATABASE ──────────────────────────────────────────────
# Para rodar SEM docker (local), use localhost. Dentro do container,
# o docker-compose.yml injeta DATABASE_URL apontando para `postgres`.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_saas?schema=public

# ─── REDIS ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT (🔒 S3 — mínimo 32 caracteres em produção) ────────
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=dev-access-secret-CHANGE-ME-min-32-chars-aaaa
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret-CHANGE-ME-min-32-chars-bbb
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS (🔒 S1 — origens permitidas, vírgula-separado) ──
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# ─── S3 / MinIO ────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=whatsapp-saas-files
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ─── EVOLUTION API ─────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=

# ─── RATE LIMIT ────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
