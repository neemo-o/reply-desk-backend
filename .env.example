NODE_ENV=development
PORT=3000

# Pool de conexões Postgres (P1 — ajuste para 15-20 em hardware 2vCPU/4GB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_saas?schema=public&connection_limit=20&pool_timeout=20

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 🔒 S3 — JWT secrets DEVEM ter no mínimo 32 caracteres.
# Em produção, gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=dev-access-secret-CHANGE-ME-min-32-chars-aaaa
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret-CHANGE-ME-min-32-chars-bbb
JWT_REFRESH_EXPIRES_IN=7d

# 🔒 S1 — Origens permitidas para CORS (vírgula-separado). Vazio = tudo bloqueado.
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=whatsapp-saas-files
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
